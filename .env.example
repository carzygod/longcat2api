# longcat2api environment example

# Service auth. Use a long random value in production.
LONGCAT_API_KEY=change-this-longcat-key

# Listen address.
LONGCAT_HOST=0.0.0.0
LONGCAT_PORT=9090

# Runtime data. These paths contain browser login state and must be protected.
LONGCAT_DATA_DIR=/app/data
LONGCAT_BROWSER_DATA=/app/data/browser
LONGCAT_SESSION_FILE=/app/data/longcat_session.json

# Browser behavior.
LONGCAT_HEADLESS=true
LONGCAT_START_BROWSER=true
LONGCAT_TIMEZONE=Asia/Shanghai

# Generation wait limits.
LONGCAT_CHAT_TIMEOUT=120
LONGCAT_IMAGE_TIMEOUT=240
LONGCAT_VIDEO_TIMEOUT=900

# Admin request log length.
LONGCAT_REQUEST_LOG_LIMIT=200

# Optional browser overrides.
# LONGCAT_CHROMIUM_EXECUTABLE_PATH=/usr/bin/google-chrome
# LONGCAT_CHROMIUM_CHANNEL=chrome
